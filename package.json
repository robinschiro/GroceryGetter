{
  "name": "grocery-getter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1 --configLoader native",
    "build": "tsc && vite build --configLoader native",
    "import:recipes": "tsx scripts/import-recipes.ts",
    "import:recipes:commit": "tsx scripts/import-recipes.ts --commit",
    "sync:recipes": "tsx scripts/import-recipes.ts --sync",
    "sync:recipes:commit": "tsx scripts/import-recipes.ts --sync --commit",
    "preview": "vite preview --host 127.0.0.1 --configLoader native",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.13.0",
    "tsx": "^4.19.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.11",
    "typescript": "^5.7.2"
  }
}
